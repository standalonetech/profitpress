{
	"name": "profitpress/profitpress",
	"description": "ProfitPress — Real Profit Analytics for WooCommerce.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9",
		"wp-coding-standards/wpcs": "^3.0",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"php-stubs/woocommerce-stubs": "^9.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"autoload": {
		"psr-4": {
			"ProfitPress\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"ProfitPress\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"analyze": "phpstan analyse",
		"test": "phpunit"
	}
}
